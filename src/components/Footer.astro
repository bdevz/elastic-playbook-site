---
import { bookPath } from "../lib/utils";
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <div>
        <h3>Bharat</h3>
        <p class="meta">
          Writing, workshops, and architecture guidance around Elastic, AI,
          search, observability, and production-grade systems.
        </p>
      </div>

      <div>
        <h3>The Elastic Playbook</h3>
        <p class="meta">
          The canonical home for the book, the flagship articles, and the
          checklists that support workshop and consulting conversations.
        </p>
        <a href={bookPath("/articles")}>Browse articles</a>
      </div>

      <div>
        <h3>Current focus</h3>
        <p class="meta">
          Helping teams make better decisions about retrieval, observability,
          AI workflows, and safe production boundaries.
        </p>
        <a href={bookPath("/workshops")}>See workshop options</a>
      </div>
    </div>

    <p class="meta">
      `bharats.com` is the root site. `bharats.com/elastic-playbook` is the
      book companion and publishing surface.
    </p>
  </div>
</footer>
