---
interface Props {
  variant?: "primary" | "ghost";
  full?: boolean;
  href?: string;
  type?: "button" | "submit";
}

const {
  variant = "primary",
  full = false,
  href,
  type = "button",
} = Astro.props as Props;
const className = ["btn", `btn--${variant}`, full && "btn--full"]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a class={className} href={href}>
      <slot />
    </a>
  ) : (
    <button class={className} type={type}>
      <slot />
    </button>
  )
}
