---
import { navigation, siteMeta } from "../lib/site";
---

<header class="topbar">
  <div class="topbar__inner">
    <a class="topbar__brand" href="/">
      <span class="topbar__mark">B</span>
      <strong>{siteMeta.title}</strong>
      <span>Elastic + AI</span>
    </a>

    <nav class="topbar__nav" aria-label="Primary">
      {navigation.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
      <span class="sep" />
      <button class="tog" id="palette-btn" aria-label="Toggle palette">
        <svg
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>
