---
import { navigation, siteMeta } from "../lib/site";
import { withBase } from "../lib/utils";
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-brand" href={withBase("/")}>
      <span class="site-brand__eyebrow">Bharat's field guide</span>
      <span class="site-brand__title">{siteMeta.title}</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {navigation.map((item) => (
        <a href={withBase(item.href)}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>
