---
import BaseLayout from "../layouts/BaseLayout.astro";
import Plate from "../components/Plate.astro";
import SectionHead from "../components/SectionHead.astro";
import Button from "../components/Button.astro";
import Chip from "../components/Chip.astro";
import { awardMeta, recognitionLinks, siteMeta } from "../lib/site";

const gallerySections = [
  {
    num: "03",
    title: "Awards and Elastic field record",
    meta: "Awards week and Elastic spaces",
    copy:
      "A visual record from the Elastic office, event spaces, customer-proof moments, and the awards-week atmosphere around the recognition.",
    photos: [
      {
        src: "/gallery/img-2517-cisco-quote.jpeg",
        alt: "A Cisco customer quote slide shown during an Elastic event.",
        title: "Customer proof on screen",
        meta: "Event field note",
        caption:
          "One of the strongest recurring themes in the Elastic world: the work has to show up in systems, not slogans.",
      },
      {
        src: "/gallery/img-2518-bk-elastic-office.jpeg",
        alt: "BK Bhate standing in front of an Elastic logo wall.",
        title: "At the Elastic office",
        meta: "Recognition week",
        caption:
          "A straightforward marker of the relationship: close enough to the platform and the people to matter.",
      },
      {
        src: "/gallery/img-2519-elastic-sign.jpeg",
        alt: "Elastic logo on an office wall.",
        title: "Inside the Elastic office",
        meta: "Context",
        caption:
          "A small but useful visual: this work lives close to the product, not at a distance.",
      },
      {
        src: "/gallery/img-0575-event-entrance.jpeg",
        alt: "Entrance signage for an Elastic event venue in New York City.",
        title: "Elastic event entrance",
        meta: "NYC event week",
        caption:
          "The physical event trail matters because it shows this reputation was built in the actual community, not only online.",
      },
      {
        src: "/gallery/img-0577-social-board.jpeg",
        alt: "A social leaderboard screen at an Elastic event.",
        title: "Event energy on display",
        meta: "Community signal",
        caption:
          "Elastic events tend to blur product, community, and operator culture. That overlap is part of the story.",
      },
      {
        src: "/gallery/img-0579-elasticlaw-slide.jpeg",
        alt: "A large screen showing an Elastic slide about ElasticLAW tokens.",
        title: "Elastic on the big screen",
        meta: "Conference room",
        caption:
          "Useful to show the scale and texture of the environments where these conversations happen.",
      },
      {
        src: "/gallery/img-0580-kevin-pura-stage.jpeg",
        alt: "Elastic executive Kevin Pura speaking on stage.",
        title: "Executive perspective",
        meta: "Elastic leadership",
        caption:
          "Part of staying relevant is staying close to how Elastic leadership frames the platform in public.",
      },
      {
        src: "/gallery/img-0581-shay-bahs-stage.jpeg",
        alt: "A stage screen showing Shay Banon and Bahs Azarmi at an Elastic event.",
        title: "Founders and platform direction",
        meta: "Elastic leadership",
        caption:
          "The platform story is shaped as much by these rooms and keynotes as by the docs and release notes.",
      },
      {
        src: "/gallery/img-0586-venue-floor.jpeg",
        alt: "An event venue floor during an Elastic gathering.",
        title: "Where the conversations happen",
        meta: "Field setting",
        caption:
          "A lot of the best Elastic insight comes from direct conversations with practitioners and product people in rooms like this.",
      },
      {
        src: "/gallery/img-5878-elastic-banner.jpeg",
        alt: "An Elastic banner inside an event venue hallway.",
        title: "Elastic in the wild",
        meta: "Venue detail",
        caption:
          "One of the quieter images in the set, but good for credibility because it reads as real event texture.",
      },
      {
        src: "/gallery/img-5879-elastic-bike.jpeg",
        alt: "A bicycle with Elastic branding in an office space.",
        title: "Office detail",
        meta: "Elastic workspace",
        caption:
          "The gallery works best when it mixes formal recognition with the smaller moments that make the ecosystem feel lived-in.",
      },
      {
        src: "/gallery/img-5915-bk-elastic-mural.jpeg",
        alt: "BK Bhate standing in front of an Elastic mural.",
        title: "Partner and practitioner",
        meta: "Recognition week",
        caption:
          "This is the image that most clearly bridges personal reputation and platform credibility.",
      },
      {
        src: "/gallery/img-6643-event-signage.jpeg",
        alt: "BK Bhate standing in front of large Elastic event branding.",
        title: "Awards-week branding",
        meta: "ElasticON setting",
        caption:
          "Strong event branding helps anchor the whole gallery in a recognizable Elastic moment.",
      },
      {
        src: "/gallery/img-6642-elastic-lobby-display.jpeg",
        alt: "A large Elastic display and event desk inside a venue.",
        title: "Elastic venue display",
        meta: "Event week",
        caption:
          "A final room-setting image to frame the award and community photos that follow.",
      },
    ],
  },
  {
    num: "04",
    title: "Talks, demos, and technical depth",
    meta: "Meetups and working sessions",
    copy:
      "These photos are less about glamour and more about repeated public technical work: talks, walkthroughs, demos, architecture diagrams, and live explanations.",
    photos: [
      {
        src: "/gallery/img-5887-room-wide-talk.jpeg",
        alt: "A wide shot of BK Bhate speaking at an Elastic community session.",
        title: "Room-wide meetup view",
        meta: "Community talk",
        caption:
          "A good reminder that expertise compounds in public, one room and one explanation at a time.",
      },
      {
        src: "/gallery/img-5888-podium-intro.jpeg",
        alt: "BK Bhate at a podium before an Elastic-branded screen.",
        title: "At the podium",
        meta: "Meetup session",
        caption:
          "Clean podium shots help the site read as working credibility rather than just a personal brand page.",
      },
      {
        src: "/gallery/img-5889-podium-intro-vertical.jpeg",
        alt: "BK Bhate standing at a podium with an Elastic slide in the background.",
        title: "Opening the session",
        meta: "Talk setup",
        caption:
          "The early moments of a talk matter because they show the operator side of the story, not just the polished result.",
      },
      {
        src: "/gallery/img-5890-pandemic-case-study.jpeg",
        alt: "A presentation slide about how Elasticsearch helped control pandemic and disease case tracking.",
        title: "Public-sector use case",
        meta: "Case study",
        caption:
          "A concrete example of Elastic being used as infrastructure for operational decision-making, not only analytics.",
      },
      {
        src: "/gallery/img-5891-pandemic-case-study-wide.jpeg",
        alt: "A wider shot of the pandemic case-study presentation slide.",
        title: "Case study in context",
        meta: "Working session",
        caption:
          "Showing the room as well as the slide makes the technical work feel lived and delivered, not just drafted.",
      },
      {
        src: "/gallery/img-5896-proposed-solution.jpeg",
        alt: "A slide titled What you proposed during a Hyperflex and Elastic presentation.",
        title: "Architecture proposal walkthrough",
        meta: "Search use case",
        caption:
          "One of the stronger proof points for consulting credibility: turning architecture into something people can actually see and debate.",
      },
      {
        src: "/gallery/img-5897-proposed-solution-gesture.jpeg",
        alt: "BK Bhate gesturing while presenting a proposed Elastic-based solution.",
        title: "Explaining the tradeoffs",
        meta: "Workshop moment",
        caption:
          "The site should signal that the value is not only in slides, but in helping teams think through them.",
      },
      {
        src: "/gallery/img-5898-elastic-ecosystem.jpeg",
        alt: "A slide showing an Elastic ecosystem solution architecture.",
        title: "Elastic ecosystem framing",
        meta: "System design",
        caption:
          "Exactly the kind of visual that supports the broader thesis behind The Elastic Playbook.",
      },
      {
        src: "/gallery/img-5900-layered-stack.jpeg",
        alt: "BK Bhate speaking in front of a slide showing stacked Elastic architecture layers.",
        title: "Layered platform view",
        meta: "Platform framing",
        caption:
          "This is the argument in visual form: Elastic as part of a layered operational substrate.",
      },
      {
        src: "/gallery/img-5902-architecture-diagram.jpeg",
        alt: "A slide showing an architecture diagram during a Hyperflex presentation.",
        title: "Architecture diagram review",
        meta: "Technical depth",
        caption:
          "Architecture diagrams are still one of the clearest ways to show seriousness in enterprise platform work.",
      },
      {
        src: "/gallery/img-5899-layered-stack-close.jpeg",
        alt: "A closer view of the layered Elastic stack slide.",
        title: "Operational layering",
        meta: "Design review",
        caption:
          "A second angle on the same slide, useful because it captures the speaker as well as the system model.",
      },
      {
        src: "/gallery/img-5907-anomaly-detection.jpeg",
        alt: "An Elastic anomaly detection jobs screen shown during a presentation.",
        title: "Live Elastic demo",
        meta: "Observability workflow",
        caption:
          "The product itself showing up on screen matters. It grounds the rest of the page in real operator work.",
      },
      {
        src: "/gallery/img-5908-single-metric-viewer.jpeg",
        alt: "A single metric viewer screen in Elastic shown during a presentation.",
        title: "Metrics on screen",
        meta: "Technical walkthrough",
        caption:
          "Another useful reality check: dashboards, metrics, and demos belong alongside higher-level thought leadership.",
      },
      {
        src: "/gallery/img-5910-room-and-audience.jpeg",
        alt: "A wide audience shot during an Elastic-related session.",
        title: "The room from the back",
        meta: "Audience signal",
        caption:
          "Public teaching is part of the credibility stack. This photo helps the page say that without overexplaining it.",
      },
      {
        src: "/gallery/img-5904-hyperflex-partner-slide.jpeg",
        alt: "A Hyperflex deck cover slide with Elastic partner branding.",
        title: "Hyperflex partner deck",
        meta: "Partner context",
        caption:
          "The cleanest single image for linking the Hyperflex brand back to the Elastic partner relationship.",
      },
    ],
  },
  {
    num: "05",
    title: "Community and leadership moments",
    meta: "People, not just slides",
    copy:
      "The last group rounds out the story with people and community moments that make the technical record feel human and connected.",
    photos: [
      {
        src: "/gallery/img-6620-leadership-photo-1.jpeg",
        alt: "BK Bhate standing with an Elastic leader during an event week.",
        title: "Leadership moment",
        meta: "Elastic network",
        caption:
          "Relationship capital matters in enterprise work, especially when it is paired with real technical execution.",
      },
      {
        src: "/gallery/img-6618-leadership-photo-2.jpeg",
        alt: "BK Bhate standing with an Elastic leader in front of city windows.",
        title: "Awards-week conversation",
        meta: "Elastic network",
        caption:
          "A second frame from the same set, useful because it feels candid rather than staged.",
      },
      {
        src: "/gallery/img-6616-leadership-photo-3.jpeg",
        alt: "BK Bhate posing with an Elastic leader during the recognition week.",
        title: "Shared frame with leadership",
        meta: "Recognition week",
        caption:
          "These photos work best as evidence of proximity and community standing, not as celebrity shots.",
      },
      {
        src: "/gallery/img-6614-leadership-photo-4.jpeg",
        alt: "BK Bhate and an Elastic leader smiling during an event week.",
        title: "Community trust",
        meta: "Elastic network",
        caption:
          "A reminder that credibility is built through long-term contribution, not one announcement.",
      },
      {
        src: "/gallery/img-6634-community-photo.jpeg",
        alt: "BK Bhate with another attendee at an Elastic event.",
        title: "Elastic community",
        meta: "Partner ecosystem",
        caption:
          "One of the strongest themes across the whole gallery is simple: this work is embedded in a real community of practitioners.",
      },
      {
        src: "/gallery/img-6633-community-photo-2.jpeg",
        alt: "BK Bhate with another member of the Elastic community at an event.",
        title: "Peer network",
        meta: "Field relationships",
        caption:
          "A final people-centered image to keep the page grounded in relationships, not only artifacts.",
      },
    ],
  },
];
---

<BaseLayout
  title={`Gallery | ${siteMeta.title}`}
  description="Public record of BK Bhate's Elastic recognition, press coverage, field work, and community moments."
  section="Recognition gallery"
  ticks={["01", "02", "03", "04", "05"]}
>
  <style>
    .recognition-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(260px, 0.9fr);
      gap: 1.25rem;
      align-items: start;
    }

    .recognition-copy {
      display: grid;
      gap: 1rem;
    }

    .recognition-lede {
      max-width: 42rem;
      font-size: 1.05rem;
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .hero-photo {
      display: grid;
      gap: 0.75rem;
      padding: 0.9rem;
      border: 1px solid var(--rule);
      border-radius: var(--radius-md);
      background: var(--card-strong);
    }

    .hero-photo img,
    .gallery-card img {
      width: 100%;
      height: auto;
      border: 1px solid var(--rule-soft);
      border-radius: calc(var(--radius-md) - 4px);
      background: var(--paper-warm);
    }

    .hero-photo figcaption,
    .gallery-card figcaption {
      display: grid;
      gap: 0.35rem;
    }

    .caption-title {
      color: var(--ink);
      font-size: 0.98rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .caption-meta {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.66rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .caption-copy {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.45;
    }

    .button-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .press-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: 1rem;
    }

    .press-card {
      display: grid;
      gap: 0.75rem;
      padding: 1.15rem;
      border: 1px solid var(--rule);
      border-radius: var(--radius-md);
      background: var(--card-strong);
      color: inherit;
      text-decoration: none;
      transition:
        transform 140ms ease,
        box-shadow 160ms ease,
        border-color 160ms ease;
    }

    .press-card:hover {
      transform: translateY(-2px);
      border-color: var(--ink);
      box-shadow: 0 22px 40px -24px rgba(20, 32, 42, 0.22);
    }

    .press-card__eyebrow,
    .gallery-intro {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.55;
    }

    .press-card__source {
      color: var(--copper);
      font-family: var(--mono);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .press-card__title {
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.15rem;
      font-weight: 500;
      letter-spacing: -0.01em;
    }

    .press-card__foot {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .gallery-intro {
      max-width: 44rem;
      margin-bottom: 1rem;
    }

    .gallery-masonry {
      columns: 3 18rem;
      column-gap: 1rem;
    }

    .gallery-card {
      break-inside: avoid;
      display: grid;
      gap: 0.75rem;
      margin: 0 0 1rem;
      padding: 0.85rem;
      border: 1px solid var(--rule);
      border-radius: var(--radius-md);
      background: var(--card-strong);
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.6) inset,
        0 12px 24px -20px rgba(20, 32, 42, 0.24);
    }

    @media (max-width: 960px) {
      .gallery-masonry {
        columns: 2 16rem;
      }
    }

    @media (max-width: 820px) {
      .recognition-hero {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 540px) {
      .gallery-masonry {
        columns: 1;
      }
    }
  </style>

  <Plate>
    <SectionHead num="01" title="Recognition" meta="Elastic and public proof" />
    <div class="section-rule"></div>
    <div class="section-body recognition-hero">
      <div class="recognition-copy">
        <p class="hero__eyebrow">Verified by Elastic</p>
        <h1>{awardMeta.title}</h1>
        <p class="recognition-lede">
          Recognized by Elastic as the 2025 Certified Professional of the Year.
          This page keeps the source trail together: the official Elastic pages,
          the public write-ups, and the field photos that show the work in rooms,
          on stage, and inside the Elastic ecosystem.
        </p>
        <div class="chip-row">
          <Chip dotColor="var(--copper)">Elastic Excellence Awards</Chip>
          <Chip dotColor="var(--teal)">Community and event record</Chip>
          <Chip dotColor="var(--ink)">Press and public sources</Chip>
        </div>
        <div class="button-row">
          <Button href="#sources">See the sources</Button>
          <Button variant="ghost" href="/elastic-playbook"
            >Open The Elastic Playbook</Button
          >
        </div>
      </div>

      <figure class="hero-photo">
        <img
          src="/gallery/img-2518-bk-elastic-office.jpeg"
          alt="BK Bhate standing in front of an Elastic logo wall."
          loading="eager"
        />
        <figcaption>
          <span class="caption-title">Recognition week inside the Elastic orbit</span>
          <span class="caption-meta">Elastic office · field record</span>
          <span class="caption-copy">
            The point of this page is not to posture. It is to make the record
            visible.
          </span>
        </figcaption>
      </figure>
    </div>
  </Plate>

  <Plate id="sources">
    <SectionHead num="02" title="News and articles" meta="Source trail" />
    <div class="section-rule"></div>
    <div class="section-body">
      <div class="press-grid">
        {recognitionLinks.map((link) => (
          <a
            class="press-card"
            href={link.href}
            target="_blank"
            rel="noreferrer"
          >
            <span class="press-card__source">{link.source} · {link.kind}</span>
            <span class="press-card__title">{link.title}</span>
            <span class="press-card__eyebrow">{link.summary}</span>
            <span class="press-card__foot">Open source →</span>
          </a>
        ))}
      </div>
    </div>
  </Plate>

  {gallerySections.map((section) => (
    <Plate>
      <SectionHead num={section.num} title={section.title} meta={section.meta} />
      <div class="section-rule"></div>
      <div class="section-body">
        <p class="gallery-intro">{section.copy}</p>
        <div class="gallery-masonry">
          {section.photos.map((photo) => (
            <figure class="gallery-card">
              <img src={photo.src} alt={photo.alt} loading="lazy" />
              <figcaption>
                <span class="caption-title">{photo.title}</span>
                <span class="caption-meta">{photo.meta}</span>
                <span class="caption-copy">{photo.caption}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </Plate>
  ))}
</BaseLayout>
