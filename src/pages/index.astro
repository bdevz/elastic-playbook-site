---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import CTABox from "../components/CTABox.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { bookMeta, siteMeta } from "../lib/site";
import { bookPath, sortByPublishedDesc } from "../lib/utils";

const articles = sortByPublishedDesc(
  await getCollection("articles", ({ data }) => data.featured),
).slice(0, 2);

const focusAreas = [
  "Elastic in the AI stack: retrieval, context, observability, and security",
  "Operator-grade guidance for teams shipping AI systems into production",
  "Workshops and architecture reviews that turn writing into rollout decisions",
];

const proofPoints = [
  {
    title: "What I write",
    copy:
      "Long-form technical writing aimed at enterprise teams making architecture decisions, not chasing demos.",
  },
  {
    title: "What I help with",
    copy:
      "Architecture reviews, agentic-search design, LLM observability, and safer workflow boundaries around Elastic plus AI.",
  },
  {
    title: "What this site is",
    copy:
      "A simple home for my work, with The Elastic Playbook as the flagship publishing and consulting surface.",
  },
];
---

<BaseLayout
  title={`${siteMeta.title} | Elastic, AI, and enterprise platform work`}
  description={siteMeta.description}
>
  <section class="hero">
    <div>
      <span class="hero__eyebrow">Elastic, AI, and platform systems</span>
      <h1>Bharat writes and works where search, observability, and AI architecture meet</h1>
    </div>

    <p>
      This is the home site for my writing, workshop offers, and architecture
      work. The main project here is <em>{bookMeta.title}</em>, a book and
      companion site about using Elastic as the context, observability, and
      security layer for agentic AI.
    </p>

    <div class="button-row">
      <a class="button" href={bookPath("/")}>Explore the playbook</a>
      <a class="button-secondary" href={bookPath("/workshops")}>See workshop options</a>
    </div>

    <ul class="feature-list">
      {focusAreas.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section class="section">
    <SectionHeader
      eyebrow="Profile"
      title="A practitioner-first home page"
      copy="The root site stays intentionally simple. It should tell people what I do, what the flagship work is, and where to go next."
    />

    <div class="grid">
      {proofPoints.map((item) => (
        <article class="card">
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeader
      eyebrow="Selected writing"
      title="Start with the public proof layer"
      copy="These are the first two flagship articles from The Elastic Playbook. They do the heavy lifting for search discovery, trust, and consulting relevance."
    />

    <div class="grid">
      {articles.map((article) => (
        <ArticleCard article={article} />
      ))}
    </div>
  </section>

  <section class="section">
    <div class="grid">
      <div class="panel" style="padding: 1.4rem;">
        <span class="section__eyebrow">Flagship project</span>
        <h2>{bookMeta.title}</h2>
        <p>
          The book argues that Elastic in 2026 is no longer just search
          infrastructure. It is becoming the context, retrieval,
          observability, and security substrate for agentic AI.
        </p>
        <a href={bookPath("/")}>See the playbook</a>
      </div>

      <CTABox
        title="Turn the writing into a working session"
        copy="If the architecture problem is real and time-sensitive, the playbook becomes the starting point for a workshop or platform review."
        label="Open the workshops page"
        href="/workshops"
      />
    </div>
  </section>
</BaseLayout>
