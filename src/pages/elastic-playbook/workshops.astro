---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { bookMeta } from "../../lib/site";

const workshops = [
  {
    title: "Elastic + AI architecture review",
    copy:
      "For teams deciding where Elastic should sit in the AI stack, and which boundaries belong in the platform versus the application.",
  },
  {
    title: "Agentic search design workshop",
    copy:
      "For teams designing retrieval, tool use, refusal behavior, and review boundaries for search-first agent workflows.",
  },
  {
    title: "LLM observability and operator review",
    copy:
      "For teams that need prompt lineage, traceability, cost visibility, and a replayable incident path before scaling production AI workflows.",
  },
];
---

<BaseLayout
  title={`Workshops | ${bookMeta.title}`}
  description="Workshops and advisory support for teams using Elastic across search, observability, and security in AI-era systems."
>
  <section class="hero">
    <div>
      <span class="hero__eyebrow">Working sessions</span>
      <h1>Use the book and field notes to frame the real architecture question</h1>
    </div>

    <p>
      These sessions are meant for teams dealing with a real platform decision,
      not generic inspiration. The goal is to leave with sharper boundaries, a
      cleaner operating model, and a rollout path that can survive architecture
      review.
    </p>
  </section>

  <section class="section">
    <SectionHeader
      eyebrow="Formats"
      title="Three useful starting points"
      copy="Each option maps directly to the strongest chapter and article clusters."
    />

    <div class="grid">
      {workshops.map((workshop) => (
        <article class="card">
          <h3>{workshop.title}</h3>
          <p>{workshop.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="cta-box">
      <h3>How to use this page</h3>
      <p>
        Start with the article or checklist that most closely matches your
        situation. If it maps cleanly to your environment, that usually means
        the underlying issue is substantial enough to merit a focused design
        review or working session.
      </p>
      <p class="meta">
        If you want to compare notes, reach out at `hi@bharats.com`.
      </p>
    </div>
  </section>
</BaseLayout>
