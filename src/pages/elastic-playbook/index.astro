---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { bookMeta } from "../../lib/site";
import { bookPath, sortByPublishedDesc } from "../../lib/utils";
import Plate from "../../components/Plate.astro";
import SectionHead from "../../components/SectionHead.astro";
import Reel from "../../components/Reel.astro";
import Button from "../../components/Button.astro";
import Chip from "../../components/Chip.astro";

const articles = sortByPublishedDesc(
  await getCollection("articles", ({ data }) => data.featured),
).slice(0, 3);
const resources = sortByPublishedDesc(
  await getCollection("resources", ({ data }) => data.featured),
).slice(0, 2);

const chapterClusters = [
  "The platform shift: Elastic as the context layer for agentic AI",
  "Search reimagined: retrieval, reranking, agentic search, and production RAG",
  "Observability for the AI era: prompts, traces, tool calls, cost, and reliability",
  "Security meets AI: guardrails, governance, and security workflows",
  "Putting it together: reference architectures and what to adopt now",
];

const workshops = [
  {
    title: "Elastic + AI architecture review",
    copy:
      "For teams deciding where Elastic should sit in the AI stack and which boundaries belong in the platform versus the application.",
  },
  {
    title: "Agentic search design workshop",
    copy:
      "For teams designing retrieval, tool use, refusal behavior, and review boundaries for search-first agent workflows.",
  },
  {
    title: "LLM observability and operator review",
    copy:
      "For teams that need prompt lineage, traceability, cost visibility, and a replayable incident path before scaling production AI workflows.",
  },
];
---

<BaseLayout
  title={`${bookMeta.title} | Context, observability, and security for agentic AI`}
  description={bookMeta.description}
  section="The Elastic Playbook"
  ticks={["01", "02", "03", "04", "05"]}
>
  <style>
    .book-hero {
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 32px;
      align-items: center;
      padding: 2rem 1.75rem;
    }

    .book-cover {
      position: relative;
      overflow: hidden;
      aspect-ratio: 2 / 3;
      border: 1px solid var(--rule);
      border-radius: 6px;
      background: #14202a;
      box-shadow:
        0 24px 48px -20px rgba(20, 32, 42, 0.45),
        8px 0 0 -4px #8b5a2b;
    }

    .book-cover svg {
      width: 100%;
      height: 100%;
      display: block;
    }

    .book-hero__kicker,
    .workshop__kicker {
      color: var(--copper);
      font-family: var(--mono);
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
    }

    .book-hero__title {
      margin-top: 12px;
      color: var(--ink);
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 3.2rem);
      font-weight: 400;
      line-height: 1.05;
      letter-spacing: -0.025em;
    }

    .book-hero__title em {
      font-style: italic;
      font-weight: 500;
    }

    .book-hero__sub {
      max-width: 42rem;
      margin-top: 14px;
      color: var(--ink-soft);
      font-size: 1.05rem;
    }

    .book-hero__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      overflow: hidden;
      border: 1px solid var(--rule);
      border-radius: var(--radius-md);
      background: var(--card-strong);
    }

    .stat {
      padding: 18px;
      border-right: 1px solid var(--rule-soft);
    }

    .stat:last-child {
      border-right: 0;
    }

    .stat__n {
      color: var(--ink);
      font-family: var(--serif);
      font-size: 2.1rem;
      font-weight: 500;
      line-height: 1;
      letter-spacing: -0.02em;
    }

    .stat__l {
      margin-top: 8px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .toc {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 32px;
    }

    .toc__row {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: baseline;
      padding: 12px 0;
      border-top: 1px dashed var(--rule);
    }

    .toc__row:first-child,
    .toc__row:nth-child(2) {
      border-top: 0;
    }

    .toc__n {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
    }

    .toc__t {
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.05rem;
      font-weight: 500;
      letter-spacing: -0.01em;
    }

    .article {
      display: grid;
      grid-template-columns: 110px 1fr auto;
      gap: 20px;
      align-items: flex-start;
      padding: 20px 0;
      border-top: 1px solid var(--rule-soft);
      color: inherit;
      text-decoration: none;
    }

    .article:first-child {
      border-top: 0;
      padding-top: 4px;
    }

    .article__meta {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.4;
    }

    .article__kicker {
      color: var(--copper);
      font-weight: 600;
    }

    .article__title {
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.3rem;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.015em;
    }

    .article__dek {
      margin-top: 6px;
      color: var(--ink-soft);
      font-size: 0.95rem;
    }

    .article__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 10px;
    }

    .article__tag {
      padding: 3px 8px;
      border: 1px solid var(--rule);
      border-radius: 999px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .article__arrow {
      padding-top: 4px;
      color: var(--muted);
      font-size: 1.2rem;
    }

    .res-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .res {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 18px;
      border: 1px solid var(--rule);
      border-radius: var(--radius-md);
      background: var(--card-strong);
      color: inherit;
      text-decoration: none;
    }

    .res__head,
    .res__foot {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .res__kind {
      color: var(--copper);
      font-weight: 600;
    }

    .res__title {
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: 500;
    }

    .res__sub {
      color: var(--ink-soft);
      font-size: 0.9rem;
    }

    .res__foot {
      margin-top: auto;
      padding-top: 10px;
      border-top: 1px dashed var(--rule);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
    }

    .workshop {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: center;
      padding: 22px;
      border: 1px solid var(--rule);
      border-radius: var(--radius-md);
      background: var(--paper-warm);
    }

    .workshop + .workshop {
      margin-top: 12px;
    }

    .workshop__title {
      margin-top: 8px;
      color: var(--ink);
      font-family: var(--serif);
      font-size: 1.4rem;
      font-weight: 500;
      letter-spacing: -0.015em;
    }

    .workshop__copy {
      margin-top: 8px;
      color: var(--ink-soft);
      font-size: 0.95rem;
    }

    .workshop__aside {
      color: var(--muted);
      font-family: var(--mono);
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      text-align: right;
    }

    @media (max-width: 820px) {
      .book-hero,
      .toc,
      .res-grid,
      .workshop {
        grid-template-columns: 1fr;
      }

      .book-hero {
        padding: 1.25rem;
      }

      .book-cover {
        max-width: 220px;
      }

      .article {
        grid-template-columns: 1fr auto;
      }

      .article__meta {
        grid-column: 1 / -1;
      }

      .stats {
        grid-template-columns: 1fr 1fr;
      }

      .workshop__aside {
        text-align: left;
      }
    }
  </style>

  <Plate>
    <SectionHead num="EP" title="Canonical home" meta="Vol. 01 · 2026" />
    <div class="section-rule"></div>
    <div class="book-hero">
      <div class="book-cover" aria-hidden="true">
        <svg viewBox="0 0 240 360" preserveAspectRatio="xMidYMid slice">
          <rect width="240" height="360" fill="#14202a"></rect>
          <rect
            x="16"
            y="16"
            width="208"
            height="328"
            fill="none"
            stroke="#8b5a2b"
            stroke-width="1"
          ></rect>
          <g transform="translate(120,140)" fill="none" stroke="#8b5a2b" stroke-width="1">
            <circle r="52"></circle>
            <circle r="38"></circle>
            <circle r="24"></circle>
            <circle r="10"></circle>
            <line x1="-62" y1="0" x2="62" y2="0" stroke-dasharray="2 3"></line>
            <line x1="0" y1="-62" x2="0" y2="62" stroke-dasharray="2 3"></line>
          </g>
          <text
            x="120"
            y="244"
            text-anchor="middle"
            font-family="JetBrains Mono, monospace"
            font-size="7"
            fill="#8b5a2b"
            letter-spacing="2"
          >
            FIG. A · SUBSTRATE
          </text>
          <text
            x="120"
            y="282"
            text-anchor="middle"
            font-family="Fraunces, serif"
            font-style="italic"
            font-size="17"
            fill="#f2ece1"
          >
            The
          </text>
          <text
            x="120"
            y="306"
            text-anchor="middle"
            font-family="Fraunces, serif"
            font-weight="500"
            font-size="20"
            fill="#f2ece1"
          >
            Elastic Playbook
          </text>
          <text
            x="120"
            y="328"
            text-anchor="middle"
            font-family="JetBrains Mono, monospace"
            font-size="7"
            fill="#f2ece1"
            fill-opacity="0.55"
            letter-spacing="2"
          >
            BK BHATE
          </text>
        </svg>
      </div>
      <div>
        <div class="book-hero__kicker">A field guide, not a feature tour</div>
        <h1 class="book-hero__title">
          Elastic is becoming the <em>substrate</em> for agentic AI. This site is the
          public proof layer for that argument.
        </h1>
        <p class="book-hero__sub">
          Read the articles, use the checklists, and treat the workshop path as
          the moment the writing turns into a real architecture decision.
        </p>
        <div class="book-hero__meta">
          <Chip dotColor="var(--teal)">Canonical home</Chip>
          <Chip variant="avail">Built in public</Chip>
          <Chip dotColor="var(--copper)">Operator-grade patterns</Chip>
        </div>
        <div class="button-row" style="margin-top: 18px;">
          <Button href={bookPath("/book")}>Explore the book</Button>
          <Button variant="ghost" href={bookPath("/articles")}
            >Read the articles</Button
          >
        </div>
      </div>
    </div>
  </Plate>

  <section>
    <div class="stats">
      <div class="stat">
        <div class="stat__n">{chapterClusters.length}</div>
        <div class="stat__l">Thematic parts</div>
      </div>
      <div class="stat">
        <div class="stat__n">{articles.length}</div>
        <div class="stat__l">Flagship articles</div>
      </div>
      <div class="stat">
        <div class="stat__n">{resources.length}</div>
        <div class="stat__l">Resources</div>
      </div>
      <div class="stat">
        <div class="stat__n">{workshops.length}</div>
        <div class="stat__l">Workshop paths</div>
      </div>
    </div>
  </section>

  <Plate id="book">
    <SectionHead num="01" title="Book overview" meta="Working structure" />
    <div class="section-rule"></div>
    <div class="section-body">
      <div class="toc">
        {chapterClusters.map((cluster, index) => (
          <div class="toc__row">
            <span class="toc__n">{String(index + 1).padStart(2, "0")}</span>
            <span class="toc__t">{cluster}</span>
          </div>
        ))}
      </div>
      <div style="margin-top: 20px;">
        <Button variant="ghost" href={bookPath("/book")}
          >Open the full book overview</Button
        >
      </div>
    </div>
  </Plate>

  <Plate id="articles">
    <SectionHead num="02" title="Flagship articles" meta="The public proof layer" />
    <div class="section-rule"></div>
    <div class="section-body">
      {articles.map((article) => (
        <a class="article" href={bookPath(`/articles/${article.id}`)}>
          <div class="article__meta">
            <div class="article__kicker">{article.data.keyword}</div>
            <div>{article.data.published}</div>
          </div>
          <div>
            <div class="article__title">{article.data.title}</div>
            <div class="article__dek">{article.data.summary}</div>
            <div class="article__tags">
              <span class="article__tag">{article.data.keyword}</span>
              <span class="article__tag">Elastic</span>
            </div>
          </div>
          <span class="article__arrow">→</span>
        </a>
      ))}
      <div style="margin-top: 20px;">
        <Button variant="ghost" href={bookPath("/articles")} full={true}
          >Browse all articles</Button
        >
      </div>
    </div>
  </Plate>

  <Plate id="resources">
    <SectionHead
      num="03"
      title="Field resources"
      meta="Useful assets, not brochure filler"
    />
    <div class="section-rule"></div>
    <div class="section-body">
      <div class="res-grid">
        {resources.map((resource) => (
          <a class="res" href={bookPath(`/resources/${resource.id}`)}>
            <div class="res__head">
              <span class="res__kind">{resource.data.type}</span>
              <span>{resource.data.published}</span>
            </div>
            <div class="res__title">{resource.data.title}</div>
            <div class="res__sub">{resource.data.summary}</div>
            <div class="res__foot">
              <span>Use on one real workflow</span>
              <span>Open →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </Plate>

  <Plate id="workshops">
    <SectionHead
      num="04"
      title="Workshops and reviews"
      meta="Turning writing into decisions"
    />
    <div class="section-rule"></div>
    <div class="section-body">
      {workshops.map((workshop, index) => (
        <div class="workshop">
          <div>
            <div class="workshop__kicker">
              {index === 0 ? "Architecture review" : index === 1 ? "Design workshop" : "Operator review"}
            </div>
            <div class="workshop__title">{workshop.title}</div>
            <div class="workshop__copy">{workshop.copy}</div>
          </div>
          <div class="workshop__aside">
            {index === 0 ? "Decision memo" : index === 1 ? "Working session" : "Tracing path"}
          </div>
        </div>
      ))}
      <div style="margin-top: 18px;">
        <Button href={bookPath("/workshops")} full={true}
          >See workshop options</Button
        >
      </div>
    </div>
  </Plate>

  <Plate>
    <SectionHead
      num="05"
      title="The thesis on one page"
      meta="For the skim readers"
    />
    <div class="section-rule"></div>
    <div class="section-body">
      <Reel
        kicker="Chapter cluster · the shift"
        footLeft="Elastic Playbook thesis"
        footHref={bookPath("/articles")}
        footLabel="Start with the articles →"
      >
        Elastic in 2026 is no longer just search infrastructure. It is becoming
        the <em>context, retrieval, observability, and security substrate</em> for
        agentic AI. The site exists to prove that thesis one article and one
        resource at a time.
      </Reel>
    </div>
  </Plate>
</BaseLayout>
